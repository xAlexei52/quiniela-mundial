APP_NAME="Quiniela Mundial 2026"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://tudominio.com

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_ES

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# === Base de datos (Hostinger MySQL) — LO ÚNICO QUE NECESITAS LLENAR ===
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=u000000000_quiniela
DB_USERNAME=u000000000_usuario
DB_PASSWORD=tu_password

# Sesión y caché en ARCHIVO (no dependen de la BD): así no hay problema de
# "huevo y gallina" al instalar en hosting compartido.
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file

MAIL_MAILER=log
MAIL_FROM_ADDRESS="quiniela@tudominio.com"
MAIL_FROM_NAME="${APP_NAME}"

# === Quiniela: integración opcional con API de resultados ===
# Crea una cuenta gratis en https://www.football-data.org/ y pega tu token.
# Si lo dejas vacío, cargas los marcadores manualmente desde el panel admin.
RESULTS_DRIVER=football-data
RESULTS_API_KEY=397746a6970d4bcb892ab6e02bf28787
RESULTS_COMPETITION_ID=2000
RESULTS_SEASON=2026
RESULTS_BASE_URL=https://api.football-data.org/v4

# === Setup vía web (hosting sin SSH) ===
# Si lo defines, habilitas /setup/EL_TOKEN para migrar+seed una sola vez.
# Déjalo vacío (o bórralo) en producción una vez instalado.
APP_SETUP_TOKEN=

# === Panel de administración (sin login) ===
# PIN para entrar a /admin y gestionar participantes/equipos. CÁMBIALO.
APP_ADMIN_PIN=2026

# === Premios (bote) ===
# Bote total a repartir entre el top 3 (50% / 30% / 20% por defecto).
QUINIELA_PRIZE_POOL=6000
QUINIELA_CURRENCY=MXN

VITE_APP_NAME="${APP_NAME}"
